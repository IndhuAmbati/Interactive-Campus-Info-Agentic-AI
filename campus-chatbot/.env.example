# Example environment variables
# OpenAI API key
OPENAI_API_KEY=your-openai-key-here

# Groq API settings
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=mixtral-8x7b-32768

# Database (easy mode: fill these)
DB_USER=root
DB_PASSWORD=your-mysql-password-here
DB_HOST=localhost
DB_PORT=3306
MYSQL_DB_NAME=campusinfo

# Optional advanced override (not required)
# DATABASE_URL=mysql+pymysql://root:your-mysql-password-here@localhost:3306/campusinfo
# MYSQL_ADMIN_URL=mysql+pymysql://root:your-mysql-password-here@localhost:3306/mysql

# Vector store path
VECTORSTORE_PATH=faiss_index
